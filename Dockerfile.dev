# Dev image for the Next.js frontend (hot-reload). Source is bind-mounted over
# /app at runtime by docker-compose.dev.yml; node_modules is a named volume
# seeded from this image (so native modules like sharp are built for Linux, not
# the Windows host). Not for production — production uses a standalone build.
FROM node:22-bookworm-slim

WORKDIR /app

# Match the host pnpm (11.x) so the lockfile resolves identically. Installing a
# pinned pnpm is more reliable than corepack here (package.json has no
# packageManager field).
RUN npm install -g pnpm@11.5.2

# Install deps in a cached layer. pnpm-workspace.yaml MUST be present so the
# allowBuilds gate (esbuild, sharp) is honored and the lockfile resolves.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
RUN pnpm install --frozen-lockfile

# Source + .env arrive via the compose bind-mount at runtime.
EXPOSE 3000

# -H 0.0.0.0 so the container's port mapping is reachable from the host.
CMD ["pnpm", "dev", "--", "-H", "0.0.0.0", "-p", "3000"]
